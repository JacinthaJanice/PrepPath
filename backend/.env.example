# ─── Supabase (get from supabase.com → Settings → API) ───
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SECRET_KEY=your-secret-key-here
# Legacy fallback (optional): SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Server ───
PORT=3001
NODE_ENV=development

# ─── CORS (your GitHub Pages URL or localhost) ───
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://YOUR-USERNAME.github.io

# ─── App ───
APP_VERSION=3.0.0
